# --- App ---
APP_NAME=AIVOA AI-First CRM - HCP Module
APP_ENV=development
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
# MySQL - the assignment-mandated database. Update the credentials below to
# match your local MySQL user, then run the Alembic setup in
# backend/alembic/README.md before starting the server.
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost:3306/aivoa_crm?charset=utf8mb4

# Zero-setup fallback (no MySQL install needed) - uncomment to use instead:
# DATABASE_URL=sqlite:///./aivoa_crm.db

# --- Groq ---
# Create a free API key at https://console.groq.com/keys
GROQ_API_KEY=Paste your Groq API Key here
# Groq deprecated gemma2-9b-it and llama-3.3-70b-versatile. These are the
# current recommended equivalents (app/agent/llm.py also auto-corrects any
# older/deprecated model ID at call time as a safety net either way).
GROQ_MODEL=openai/gpt-oss-20b
GROQ_FALLBACK_MODEL=openai/gpt-oss-120b
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# --- LangGraph ---
LANGGRAPH_RECURSION_LIMIT=15

# --- Logging ---
LOG_LEVEL=INFO
